<?xml version="1.0"?>
<robot name="robot_name"
    xmlns:xacro="http://ros.org/wiki/xacro">


    <xacro:include filename="properties.xacro" />

    <!-- Root Link -->
    <link name="base_footprint">
    </link>
    <link name="base_link">
    </link>
    <joint name="base_foot_to_base_link" type="fixed">
        <parent link="base_link"/>
        <child link="base_footprint"/>
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
    </joint>


    <link name="base">
        <visual>
            <origin xyz="0.0 0.0 0" rpy="0.0 0.0 0.0" />
            <geometry>
                <mesh filename="package://robot_description/meshes/base.stl" scale="${scale_stl}" />
            </geometry>
            <material name="grey" />
        </visual>
        <collision>
            <geometry>
                <box size="${base_length} ${base_width} ${base_height}" />
            </geometry>
        </collision>
        <inertial>
            <mass value="${base_mass}" />
            <origin xyz="0 0 0" rpy="0 0 0" />
            <inertia ixx="${base_mass * (base_width * base_width + base_height * base_height) / 12.0}" ixy="0.0" ixz="0.0" iyy="${base_mass * (base_length * base_length + base_height * base_height) / 12.0}" iyz="0.0" izz="${base_mass * (base_length * base_length + base_width * base_width) / 12.0}" />
        </inertial>
    </link>

    <!-- Wheel macro with correct cylindrical inertia -->
    <xacro:macro name="wheel_link" params="prefix">
        <link name="${prefix}_wheel">
            <visual>
                <origin xyz="0 0 0" rpy="0 0 0" />
                <geometry>
                    <!-- <mesh filename="package://robot_description/meshes/blue_tyre.stl" scale="${scale_stl}" /> -->
                    <mesh filename="package://robot_description/meshes/blue_tyre.stl" scale="${scale_stl}" />
                </geometry>
                <material name="black" />
            </visual>
            <collision>
                <origin rpy="1.5708 0 0" xyz="0 0 0" />
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_thickness}" />
                    <!-- <mesh filename="package://robot_description/meshes/blue_tyre.stl" scale="${scale_stl}" /> -->
                </geometry>
            </collision>
            <inertial>
                <mass value="${wheel_mass}" />
                <origin xyz="0 0 0" rpy="0 0 0" />
                <inertia ixx="${wheel_mass * (3 * wheel_radius * wheel_radius + wheel_thickness * wheel_thickness) / 12}" ixy="0" ixz="0" iyy="${wheel_mass * wheel_radius * wheel_radius / 2}" iyz="0" izz="${wheel_mass * (3 * wheel_radius * wheel_radius + wheel_thickness * wheel_thickness) / 12}" />
            </inertial>
        </link>

        <gazebo reference="${prefix}_wheel">
            <mu1>5</mu1>
            <mu2>5</mu2>
        </gazebo>
        <gazebo reference="${prefix}_wheel">
            <kp>1000000</kp>
            <kd>100</kd>
        </gazebo>
    </xacro:macro>

    <!-- Use the wheel macro for all wheels -->
    <xacro:wheel_link prefix="front_right" />
    <xacro:wheel_link prefix="front_left" />
    <xacro:wheel_link prefix="rear_right" />
    <xacro:wheel_link prefix="rear_left" />

    <!-- Joints remain the same -->
    <joint name="base_link_to_base" type="fixed">
        <parent link="base_link" />
        <child link="base" />
        <origin xyz="0.0 0.0 ${wheel_radius}" rpy="0.0 0.0 0.0" />
    </joint>

    <joint name="front_right_wheel_joint" type="continuous">
        <origin xyz="${wheel_dist_x} -${wheel_dist_y} 0" rpy="0 0 0" />
        <parent link="base" />
        <child link="front_right_wheel" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="front_left_wheel_joint" type="continuous">
        <origin xyz="${wheel_dist_x} ${wheel_dist_y} 0" rpy="0 0 ${pie}" />
        <parent link="base" />
        <child link="front_left_wheel" />
        <axis xyz="0 -1 0" />
    </joint>

    <joint name="rear_right_wheel_joint" type="continuous">
        <origin xyz="-${wheel_dist_x} -${wheel_dist_y} 0" rpy="0 0 0" />
        <parent link="base" />
        <child link="rear_right_wheel" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="rear_left_wheel_joint" type="continuous">
        <origin xyz="-${wheel_dist_x} ${wheel_dist_y} 0" rpy="0 0 -${pie}" />
        <parent link="base" />
        <child link="rear_left_wheel" />
        <axis xyz="0 -1 0" />
    </joint>

    <gazebo>
        <plugin filename="gz-sim-odometry-publisher-system" name="gz::sim::systems::OdometryPublisher">
            <odom_frame>odom</odom_frame>
            <robot_base_frame>base_link</robot_base_frame>
            <odom_publisher_frequency>60</odom_publisher_frequency>
            <odom_topic>odom</odom_topic>
            <tf_topic>tf</tf_topic>
        </plugin>
    </gazebo>

    <xacro:include filename="laser.urdf.xacro" />
    <xacro:include filename="depth_camera.xacro" />
    <xacro:include filename="camera.xacro" />
    <xacro:include filename="gazebo_control.xacro" />

</robot>